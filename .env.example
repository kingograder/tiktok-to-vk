# TikTok
# Collection URL
TIKTOK_COLLECTION_URL=
# Netscape cookies file
TIKTOK_COOKIES_FILE=cookies.txt
# Optional proxy (leave empty to disable)
# Recommended for Russian users
TIKTOK_PROXY=""
# Request timeout in seconds
TIKTOK_REQUEST_TIMEOUT=30
# Delay between retries in seconds
TIKTOK_RETRY_DELAY=2

# VK
# Access token with video upload permission
VK_TOKEN=
# API version
VK_API_VERSION=5.199
# all / friends / nobody
VK_CLIP_VISIBILITY=all
# Upload timeout in seconds
VK_UPLOAD_TIMEOUT=300
# Min seconds between VK API calls
VK_MIN_INTERVAL=0.35
# Max attempts to poll VK for video processing
VK_POLL_ATTEMPTS=12
# Seconds between poll attempts
VK_POLL_INTERVAL=5

# App
# Download directory
APP_DOWNLOAD_DIR=data/downloads
# Seconds between cycles (daemon mode)
APP_CHECK_INTERVAL=3600
# SQLite database path
APP_DB_PATH=data/database.db
# Log file path (leave empty to disable file logging)
APP_LOG_FILE=logs/debug.log
# True = rotate 90deg, False = pad with black bars
APP_ROTATE_VIDEO=False
# Number of concurrent downloads
APP_CONCURRENT_DOWNLOADS=3
# Max retries per video
APP_MAX_RETRIES=3
# Delete files after successful upload
APP_CLEAR_DOWNLOADS=true
# Target video width in pixels
APP_TARGET_WIDTH=1080
# Target video height in pixels
APP_TARGET_HEIGHT=1920

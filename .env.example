# TikTok
TIKTOK_COLLECTION_URL=           # Collection URL
TIKTOK_COOKIES_FILE=cookies.txt  # Netscape cookies file
TIKTOK_PROXY=                    # Optional proxy
TIKTOK_REQUEST_TIMEOUT=30        # Request timeout in seconds
TIKTOK_RETRY_DELAY=2             # Delay between retries in seconds

# VK
VK_TOKEN=                        # Access token with video upload permission
VK_API_VERSION=5.199
VK_CLIP_VISIBILITY=all           # all / friends / nobody
VK_UPLOAD_TIMEOUT=300
VK_MIN_INTERVAL=0.35             # Min seconds between VK API calls
VK_POLL_ATTEMPTS=12              # Max attempts to poll VK for video processing
VK_POLL_INTERVAL=5               # Seconds between poll attempts

# App
APP_DOWNLOAD_DIR=data/downloads
APP_CHECK_INTERVAL=3600          # Seconds between cycles (daemon mode)
APP_DB_PATH=data/database.db
APP_LOG_FILE=logs/debug.log      # Leave empty to disable file logging
APP_ROTATE_VIDEO=False           # True = rotate 90deg, False = pad with black bars
APP_CONCURRENT_DOWNLOADS=3
APP_MAX_RETRIES=3
APP_CLEAR_DOWNLOADS=true         # Delete files after successful upload
APP_TARGET_WIDTH=1080
APP_TARGET_HEIGHT=1920
